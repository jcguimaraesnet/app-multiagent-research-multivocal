# Secrets — never commit real keys (Scopus, Firecrawl, OpenAI, Crossref)
.env
.env.*
!.env.example
.scopus_cookie.txt

# Full-text PDFs: heavy (~630 MB) and the Scopus ones are paywalled/copyrighted. The screened
# text lives in data/<origin>/content/full/<id>.md, which IS versioned.
data/*/content/pdf/

# WSL/Windows download metadata (alternate data streams), not a pipeline result.
*Zone.Identifier

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.python-version

# OS / editor
.DS_Store
.vscode/
