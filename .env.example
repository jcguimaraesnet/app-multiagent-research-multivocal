# Copy this file to .env and fill in the values. Never commit the real .env.
FIRECRAWL_API_KEY=
SCOPUS_API_KEY=
# MODEL_EXPERIMENT is NOT sent to the LLM; it names the subfolder that isolates one model's
# screening outputs (steps 2-4): data/<origin>/<MODEL_EXPERIMENT>/. e.g. deepseek-v4-fast
MODEL_EXPERIMENT=

# LLM endpoint (any OpenAI-compatible provider). Set these to choose the provider.
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1   LLM_API=chat
#   Azure:      LLM_BASE_URL=https://<resource>.services.ai.azure.com/openai/v1
#               LLM_MODEL=<deployment-name> (e.g. gpt-5.4-pro)   LLM_API=responses   LLM_TEMPERATURE=
# Leave LLM_BASE_URL empty to default to OpenRouter.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# LLM_API: "chat" (Chat Completions, default) or "responses" (Responses API). Some models
# (e.g. Azure gpt-5 "pro") serve ONLY the Responses API and reject /chat/completions.
LLM_API=
# LLM_TEMPERATURE: default 0.2; leave EMPTY for models that reject a custom temperature (gpt-5 "pro").
LLM_TEMPERATURE=

# Legacy fallback (used only when the LLM_* variables above are empty).
OPENROUTER_API_KEY=

# REVIEW_DRIVE_FOLDER_URL: shared Google Drive folder holding the step-4 source files (PDFs and
# Markdown). When set, the "file" column of step-4-review.xlsx (step 5) becomes a clickable link
# that opens this folder, where the reviewer finds the file by the name shown in the cell.
REVIEW_DRIVE_FOLDER_URL=

